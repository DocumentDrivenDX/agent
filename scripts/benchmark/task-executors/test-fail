#!/usr/bin/env bash
# SUMMARY: test executor that simulates execution failure for testing error handling
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage:
  test-fail  (reads task-spec.json on stdin)

This is a fake task executor for testing error handling. It writes a
result.json with final_status=invalid and exits non-zero.
EOF
  return 2
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
fi

spec="$(cat)"
if [[ -z "$spec" ]]; then
  echo "test-fail: empty task-spec on stdin" >&2
  exit 2
fi

cell_dir="$(jq -r '.cell_dir // ""' <<<"$spec")"
task_id="$(jq -r '.task_id // ""' <<<"$spec")"

if [[ -z "$cell_dir" || -z "$task_id" ]]; then
  echo "test-fail: task-spec missing one of {cell_dir, task_id}" >&2
  exit 2
fi

mkdir -p "$cell_dir"

# Write a result.json with invalid status
jq -nc \
  --arg task_id "$task_id" \
  '{
    task_id: $task_id,
    final_status: "invalid",
    invalid_class: "test_error",
    turns: 0,
    input_tokens: 0,
    output_tokens: 0,
    cached_input_tokens: 0,
    total_tokens: 0
  }' >"${cell_dir}/result.json"

exit 1
