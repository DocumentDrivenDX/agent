#!/usr/bin/env bash
# SUMMARY: test adapter that echoes back the profile with minimal command-spec for testing
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "${SCRIPT_DIR}/common.sh"

usage() {
  cat >&2 <<'EOF'
Usage:
  test-echo install <agent-artifact-path>
  test-echo command  (reads profile JSON on stdin)
EOF
  return 2
}

cmd_install() {
  local artifact="${1:-}"
  jq -cn \
    --arg src "$artifact" \
    '{install_command:"true", artifact_source:$src, binary_path:"/test-echo", harbor_plugin:null}'
}

cmd_command() {
  benchmark_adapter_read_profile test-echo >/dev/null
  # Return a minimal command spec for testing
  jq -cn '{command:["echo","test"], env:{TEST_ENV:"test_value"}, secret_env_keys:[]}'
}

main() {
  local sub="${1:-}"
  case "$sub" in
    install) shift; cmd_install "$@";;
    command) shift; cmd_command;;
    -h|--help|"") usage;;
    *) echo "test-echo: unknown subcommand: $sub" >&2; usage;;
  esac
}

main "$@"
